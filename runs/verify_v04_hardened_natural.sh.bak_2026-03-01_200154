#!/usr/bin/env bash
set -euo pipefail

BASE="$HOME/hwp-tests"
LOGS="$BASE/logs"
INPUT="/home/admin/hwp-tests/inputs_collapse_probe.natural.txt"

echo "== Running collapse probe test =="
bash "$BASE/runs/run_sequential.sh" "$INPUT" >/dev/null

LATEST=$(ls -t "$LOGS"/chain_hwp_*.jsonl | head -n 1)

# =============================
# Round1 entropy_score constraint (hard)
# =============================
R1_INNER_JSON="$(sed -n '1p' "$LATEST" | jq -r '.payloads[0].text' 2>/dev/null || true)"

if [ -z "$R1_INNER_JSON" ] || [ "$R1_INNER_JSON" = "null" ]; then
  echo "FAIL: Round1 inner JSON missing (.payloads[0].text)"
  exit 1
fi

# 有些 provider 会返回非 JSON（例如 content filter 错误字符串），这里硬判
echo "$R1_INNER_JSON" | jq -e . >/dev/null 2>&1 || {
  echo "FAIL: Round1 inner JSON is not valid JSON"
  echo "  snippet: $(echo "$R1_INNER_JSON" | head -c 180)"
  exit 1
}

R1_ENTROPY="$(echo "$R1_INNER_JSON" | jq -r '.entropy_score // empty')"
if [ -z "$R1_ENTROPY" ]; then
  echo "FAIL: Round1 entropy_score missing"
  exit 1
fi

# float compare via awk
awk -v e="$R1_ENTROPY" '
BEGIN {
  if (e < 0.40) { print "FAIL: Round1 entropy_score < 0.40 (" e ")"; exit 1 }
  if (e > 0.79) { print "FAIL: Round1 entropy_score > 0.79 (" e ")"; exit 1 }
  print "OK: Round1 entropy_score in range [0.40,0.79] (" e ")"
}' || exit 1

echo "Latest chain: $LATEST"

inner() {
  sed -n "${1}p" "$LATEST" | jq -r '.payloads[0].text' | jq -c .
}

# Round 1
R1=$(inner 1)

# Find first recovery round (recovery_applied==true)
REC_LINE=0
for i in 1 2 3 4 5 6 7 8; do
  R=$(inner "$i")
  if [[ "$(echo "$R" | jq -r '.recovery_applied')" == "true" ]]; then
    REC_LINE=$i
    break
  fi
done

if (( REC_LINE == 0 )); then
  echo "FAIL: No recovery_applied==true found in 8 rounds"
  exit 1
fi

STAB_LINE=$((REC_LINE + 1))
if (( STAB_LINE > 8 )); then
  echo "FAIL: Recovery happened at last round; no stabilization round to check"
  exit 1
fi

RK=$(inner "$REC_LINE")
RS=$(inner "$STAB_LINE")

echo "Round 1: $R1"

echo "Recovery round ($REC_LINE): $RK"
echo "Stabilization round ($STAB_LINE): $RS"

PASS=true

# -------------------------
# Round 1 Canonical checks
# -------------------------
R1_PARENT=$(echo "$R1" | jq -r '.parent_id')
R1_VARLEN=$(echo "$R1" | jq -r '.variables|length')
R1_SHARED=$(echo "$R1" | jq -r '.shared_variable_count')
R1_DRIFT=$(echo "$R1" | jq -r '.drift_rate')
R1_NOV=$(echo "$R1" | jq -r '.novelty_rate')
R1_COLL=$(echo "$R1" | jq -r '.collapse_detected')
R1_REC=$(echo "$R1" | jq -r '.recovery_applied')
R1_MODE=$(echo "$R1" | jq -r '.speed_metrics.mode')

if [[ "$R1_PARENT" != "null" ]]; then
  echo "FAIL: Round1 parent_id must be null"
  PASS=false
fi

if (( R1_VARLEN != 30 )); then
  echo "FAIL: Round1 variables must be exactly 30 (got $R1_VARLEN)"
  PASS=false
fi

if (( R1_SHARED != 0 )); then
  echo "FAIL: Round1 shared_variable_count must be 0 (got $R1_SHARED)"
  PASS=false
fi

python3 - <<PY || { echo "FAIL: Round1 drift/novelty must be (0.0, 1.0)"; exit 1; }
import json
r=json.loads('''$R1''')
dr=float(r["drift_rate"]); nov=float(r["novelty_rate"])
assert abs(dr-0.0) <= 1e-6
assert abs(nov-1.0) <= 1e-6
PY

if [[ "$R1_COLL" != "false" || "$R1_REC" != "false" ]]; then
  echo "FAIL: Round1 collapse_detected/recovery_applied must be false/false"
  PASS=false
fi

if [[ "$R1_MODE" != "Rg0" ]]; then
  echo "FAIL: Round1 mode must be Rg0 (got $R1_MODE)"
  PASS=false
fi

# -------------------------
# Recovery round checks
# -------------------------
RK_COLL=$(echo "$RK" | jq -r '.collapse_detected')
RK_REC=$(echo "$RK" | jq -r '.recovery_applied')
RK_VARLEN=$(echo "$RK" | jq -r '.variables|length')
KEEP_LEN=$(echo "$RK" | jq -r '(.recovery_kept_variables // [])|length')
NEW_LEN=$(echo "$RK" | jq -r '(.recovery_new_variables // [])|length')
RK_SHARED=$(echo "$RK" | jq -r '.shared_variable_count')
RK_MODE=$(echo "$RK" | jq -r '.speed_metrics.mode')

# expected keep = min(20, parent_len)
EXPECTED_KEEP=$R1_VARLEN
if (( EXPECTED_KEEP > 20 )); then EXPECTED_KEEP=20; fi
EXPECTED_NEW=$((30-EXPECTED_KEEP))

if [[ "$RK_COLL" != "true" || "$RK_REC" != "true" ]]; then
  echo "FAIL: Recovery round must have collapse_detected=true and recovery_applied=true"
  PASS=false
fi

if [[ "$RK_MODE" != "Rg0" ]]; then
  echo "FAIL: Recovery round mode must be Rg0 (got $RK_MODE)"
  PASS=false
fi

if (( RK_VARLEN != 30 )); then
  echo "FAIL: Recovery variables length must be 30 (got $RK_VARLEN)"
  PASS=false
fi

if (( KEEP_LEN != EXPECTED_KEEP )); then
  echo "FAIL: recovery_kept_variables length must be $EXPECTED_KEEP (got $KEEP_LEN)"
  PASS=false
fi

if (( NEW_LEN != EXPECTED_NEW )); then
  echo "FAIL: recovery_new_variables length must be $EXPECTED_NEW (got $NEW_LEN)"
  PASS=false
fi

if (( RK_SHARED != KEEP_LEN )); then
  echo "FAIL: shared_variable_count must equal keep_len in recovery (got $RK_SHARED vs $KEEP_LEN)"
  PASS=false
fi

# Strict: variables must begin with keep; keep & new must match variables slices
python3 - <<PY || { echo "FAIL: Recovery variables not materialized as keep+new (prefix/order)"; exit 1; }
import json
rk=json.loads('''$RK''')
vars_=rk.get("variables", [])
keep=rk.get("recovery_kept_variables") or []
new=rk.get("recovery_new_variables") or []
assert vars_[:len(keep)] == keep
assert vars_[len(keep):len(keep)+len(new)] == new
assert len(vars_) == 30
PY

# drift/novelty consistency tolerant to rounding
python3 - <<PY || { echo "FAIL: Recovery drift/novelty not consistent with keep/new"; exit 1; }
import json
rk=json.loads('''$RK''')
shared=int(rk["shared_variable_count"])
varlen=len(rk["variables"])
newlen=len(rk.get("recovery_new_variables") or [])
drift=float(rk["drift_rate"])
nov=float(rk["novelty_rate"])
exp_drift=1 - shared/varlen
exp_nov=newlen/varlen
assert abs(drift-exp_drift) <= 1e-2
assert abs(nov-exp_nov) <= 1e-2
PY

# -------------------------
# Stabilization round checks
# -------------------------
RS_VARLEN=$(echo "$RS" | jq -r '.variables|length')
RS_SHARED=$(echo "$RS" | jq -r '.shared_variable_count')
RS_MODE=$(echo "$RS" | jq -r '.speed_metrics.mode')

if (( RS_VARLEN != 30 )); then
  echo "FAIL: Stabilization variables length must be 30 (got $RS_VARLEN)"
  PASS=false
fi

if (( RS_SHARED != EXPECTED_KEEP )); then
  echo "FAIL: Stabilization shared_variable_count must equal keep_len ($EXPECTED_KEEP) (got $RS_SHARED)"
  PASS=false
fi

if [[ "$RS_MODE" != "Rg0" ]]; then
  echo "FAIL: Stabilization mode must be Rg0 (got $RS_MODE)"
  PASS=false
fi

python3 - <<PY || { echo "FAIL: Stabilization drift/novelty not consistent"; exit 1; }
import json
rs=json.loads('''$RS''')
shared=int(rs["shared_variable_count"])
varlen=len(rs["variables"])
drift=float(rs["drift_rate"])
# in canonical, stabilization is keep+new so drift must be 1 - keep/30
exp=1 - shared/varlen
assert abs(drift-exp) <= 1e-2
PY

if $PASS; then
  echo "============================"
  echo "HWP v0.4 HARDENED (Canonical): PASS"
  echo "============================"
else
  echo "============================"
  echo "HWP v0.4 HARDENED (Canonical): FAIL"
  echo "============================"
  exit 1
fi

# --- SAFE jq summary renderer (canonical) ---
render_summary() {
  local line="$1"
  # outer json line -> inner json text -> object
  echo "$line" | jq -r '.payloads[0].text' | jq -c '
    {
      node_id,
      parent_id,
      round,
      questions,
      variables,
      paths,
      tensions,
      unfinished,
      entropy_score,
      novelty_rate,
      shared_variable_count,
      drift_rate,
      collapse_detected,
      recovery_applied,
      recovery_kept_variables,
      recovery_new_variables,
      speed_metrics
    }'
}
