
#!/usr/bin/env bash
set -euo pipefail

# 第一个参数：输入文件路径
INPUT_FILE="$1"
if [ -z "$INPUT_FILE" ]; then
    echo "错误：请指定输入文件路径"
    exit 1
fi

LOG_DIR="$HOME/hwp-tests/logs"
SPEC_PROMPT="$HOME/hwp-tests/spec/hwp_turn_prompt.txt"
ROUNDS_PER_CHAIN=8

mkdir -p "$LOG_DIR"

while IFS= read -r line || [ -n "$line" ]; do
    [ -z "$line" ] && continue
    session_id="hwp_$(date +%s)_$RANDOM"
    log_file="$LOG_DIR/chain_${session_id}.jsonl"
    echo "开始链: $session_id，输入: $line"

    parent_vars="[]"
    parent_node="null"
    parent_recovery="false"

    > "$log_file"

    for ((r=1; r<=ROUNDS_PER_CHAIN; r++)); do
        msg="$(cat "$SPEC_PROMPT")

Meta:
- round: $r
- parent_node_id: $parent_node
- parent_recovery_applied: $parent_recovery
- parent_variables_json: $parent_vars
- input_text: $line

Now run Round $r."

        raw_output=$(OPENCLAW_LOG_LEVEL=error openclaw agent --message "$msg" --session-id "$session_id" --json 2>/dev/null || true)
        cleaned_json=$(printf "%s\n" "$raw_output" | sed -r 's/\x1B\[[0-9;]*[mK]//g' | awk 'BEGIN{f=0}{ if(!f){ i=index($0,"{"); if(i){ f=1; print substr($0,i) } } else { print } }')
        if [ -z "$cleaned_json" ]; then
            echo "警告：第 $r 轮返回空，跳过" >> "$log_file.err"
            continue
        fi
        result_json=$(echo "$cleaned_json" | jq -c '.result // .')
        echo "$result_json" >> "$log_file"

        parent_vars=$(echo "$result_json" | jq -c '.variables // []')
        parent_node=$(echo "$result_json" | jq -r '.node_id // "null"')
        parent_recovery=$(echo "$result_json" | jq -r '.recovery_applied // "false"')
        sleep 2
    done
    echo "完成链: $session_id"
done < "$INPUT_FILE"

echo "输入文件 $INPUT_FILE 处理完成。"
