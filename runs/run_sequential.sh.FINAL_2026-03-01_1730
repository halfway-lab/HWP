#!/usr/bin/env bash
set -euo pipefail

# 检查输入文件参数
INPUT_FILE="$1"
if [ -z "$INPUT_FILE" ]; then
    echo "错误：请指定输入文件路径"
    exit 1
fi

LOG_DIR="$HOME/hwp-tests/logs"
SPEC_PROMPT="$HOME/hwp-tests/spec/hwp_turn_prompt.txt"

PROMPT_FINGERPRINT="$(grep -m1 '^PROMPT_FINGERPRINT:' "$SPEC_PROMPT" | sed -E 's/^PROMPT_FINGERPRINT:[[:space:]]*//')"
[ -z "${PROMPT_FINGERPRINT:-}" ] && PROMPT_FINGERPRINT="(missing)"

ROUNDS_PER_CHAIN=8           # 明确设置为 8 轮

mkdir -p "$LOG_DIR"

# 读取输入文件，每行一条测试链
while IFS= read -r line || [ -n "$line" ]; do
    [ -z "$line" ] && continue

    # 生成唯一会话 ID
    session_id="hwp_$(date +%s)_$RANDOM"
    log_file="$LOG_DIR/chain_${session_id}.jsonl"
    echo "开始链: $session_id，输入: $line" | tee -a "$LOG_DIR/run.log"
echo "  PROMPT_FINGERPRINT: $PROMPT_FINGERPRINT" | tee -a "$LOG_DIR/run.log"


    # 初始化父节点信息（第一轮 parent 为空）
    parent_vars="[]"
    parent_node="null"
    parent_recovery="false"

    # 清空或创建当前链的日志文件
    > "$log_file"

    # 开始多轮循环
    for ((r=1; r<=ROUNDS_PER_CHAIN; r++)); do
        echo "  链 $session_id 第 $r 轮" | tee -a "$LOG_DIR/run.log"

        # 构建本轮消息，注入父节点信息
        msg="$(cat "$SPEC_PROMPT")

Meta:
- round: $r
- parent_node_id: $parent_node
- parent_recovery_applied: $parent_recovery
- parent_variables_json: $parent_vars
- input_text: $line

Now run Round $r."

        # 调用 OpenClaw 并捕获输出（屏蔽插件日志，只取 JSON）
        raw_output=$(OPENCLAW_LOG_LEVEL=error openclaw agent --message "$msg" --session-id "$session_id" --json 2>/dev/null || true)

        # 清洗输出：去掉 ANSI 控制字符，提取第一个 { 开始的有效 JSON
        cleaned_json=$(printf "%s\n" "$raw_output" | sed -r 's/\x1B\[[0-9;]*[mK]//g' | awk 'BEGIN{f=0}{ if(!f){ i=index($0,"{"); if(i){ f=1; print substr($0,i) } } else { print } }')

        if [ -z "$cleaned_json" ]; then
            echo "  警告：第 $r 轮返回空，跳过" | tee -a "$LOG_DIR/run.log"
            continue
        fi

        # 提取 result 部分（OpenClaw 返回的 JSON 结构可能包含 .result）
        result_json=$(echo "$cleaned_json" | jq -c '.result // .')

        # 保存本轮完整输出到日志
        echo "$result_json" >> "$log_file"

                # 提取下一轮需要的字段：variables, node_id, recovery_applied
        txt=$(echo "$result_json" | jq -r '.payloads[0].text // ""')
        if [[ "$txt" != \{* ]]; then
            echo "  警告：第 $r 轮 payload.text 不是 JSON（可能被内容审查拦截），写入 fallback 并继续" | tee -a "$LOG_DIR/run.log"
            echo "  SNIP: ${txt:0:140}" | tee -a "$LOG_DIR/run.log"

            # 写入一个可解析的内层 JSON（fallback）
            inner_json=$(jq -nc \
              --arg node "HWP_FALLBACK_R${r}_$(date +%Y%m%dT%H%M%S)" \
              --arg parent "$parent_node" \
              --argjson round "$r" \
              --arg snip "${txt:0:140}" \
              '{
                node_id:$node,
                parent_id:(if  == "null" then null else  end),
                round:$round,
                questions:[],
                variables:[],
                paths:[],
                tensions:[],
                unfinished:[],
                entropy_score:0,
                novelty_rate:0,
                shared_variable_count:0,
                drift_rate:1,
                collapse_detected:true,
                recovery_applied:true,
                speed_metrics:{mode:"Rg0", unfinished_inherited_count:0, action_taken:["provider_audit_block_fallback"]},
                provider_block_snip:$snip
              }')

            # 让父状态进入“安全模式”（避免后续轮继续漂）
            parent_vars="[]"
            parent_node=$(echo "$inner_json" | jq -r '.node_id')
            parent_recovery="true"
            sleep 2
            continue
        fi

        inner_json=$(printf "%s" "$txt" | jq -c 'fromjson? // .')
        if [ -n "$inner_json" ] && [ "$inner_json" != "null" ]; then
            parent_vars=$(echo "$inner_json" | jq -c '.variables // []')
            parent_node=$(echo "$inner_json" | jq -r '.node_id // "null"')
            parent_recovery=$(echo "$inner_json" | jq -r '.recovery_applied // "false"')
        else
            echo "  警告：无法解析内层 JSON，可能格式错误" | tee -a "$LOG_DIR/run.log"
            parent_vars="[]"
            parent_node="null"
            parent_recovery="false"
        fi

        # 稍微等待，避免 API 限流
        sleep 2
    done

    echo "完成链: $session_id" | tee -a "$LOG_DIR/run.log"
done < "$INPUT_FILE"

echo "输入文件 $INPUT_FILE 处理完成。" | tee -a "$LOG_DIR/run.log"
