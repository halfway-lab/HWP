# Ollama provider example
#
# Usage:
#   cp config/provider.ollama.env.example config/provider.env
#   bash runs/run_sequential.sh inputs/probe.txt

HWP_PROVIDER_TYPE=ollama
HWP_PROVIDER_NAME=ollama
OLLAMA_MODEL=your_local_model_here

# Optional:
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# HWP_OLLAMA_TEMPERATURE=0.7
# HWP_OLLAMA_TIMEOUT_SEC=120
