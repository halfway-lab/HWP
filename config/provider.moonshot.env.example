# Moonshot / Kimi provider example
#
# Usage:
#   cp config/provider.moonshot.env.example config/provider.env
#   bash runs/run_sequential.sh inputs/probe.txt

HWP_PROVIDER_TYPE=openai_compatible
HWP_PROVIDER_NAME=moonshot
HWP_LLM_API_KEY=your_moonshot_api_key_here
HWP_LLM_MODEL=your_moonshot_model_here

# Optional:
# HWP_LLM_TEMPERATURE=0.7
# HWP_LLM_TIMEOUT_SEC=120
