# HWP provider configuration
# Priority order:
# 1. CLI args
# 2. Environment variables
# 3. This file
#
# Copy to config/provider.env and edit one mode below.
# Ready-made examples:
# - config/provider.openai.env.example
# - config/provider.openrouter.env.example
# - config/provider.deepseek.env.example
# - config/provider.moonshot.env.example
# - config/provider.siliconflow.env.example
# - config/provider.groq.env.example
# - config/provider.ollama.env.example
# - config/provider.openclaw.env.example

# Recommended: let HWP choose the adapter from provider type
# HWP_PROVIDER_TYPE=openai_compatible
# HWP_PROVIDER_NAME=openrouter
# HWP_LLM_API_KEY=your_api_key_here
# HWP_LLM_MODEL=your_model_here

# Mode 1: default OpenClaw binary
# HWP_AGENT_BIN=/path/to/openclaw

# Mode 2: custom adapter command (advanced)
# HWP_AGENT_CMD=python3 adapters/openai_compatible_adapter.py

# Mode 3: replay from an existing chain log
# HWP_REPLAY_CHAIN_PATH=logs/chain_hwp_1772451330_20939.jsonl
