# OpenRouter provider example
#
# Usage:
#   cp config/provider.openrouter.env.example config/provider.env
#   bash runs/run_sequential.sh inputs/probe.txt

HWP_PROVIDER_TYPE=openai_compatible
HWP_PROVIDER_NAME=openrouter
HWP_LLM_API_KEY=your_openrouter_api_key_here
HWP_LLM_MODEL=your_openrouter_model_here

# Optional:
# HWP_LLM_TEMPERATURE=0.7
# HWP_LLM_TIMEOUT_SEC=120
