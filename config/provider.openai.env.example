# OpenAI-compatible / custom LLM provider example
#
# Usage:
#   cp config/provider.openai.env.example config/provider.env
#   bash runs/run_sequential.sh inputs/probe.txt

HWP_PROVIDER_TYPE=openai_compatible
HWP_PROVIDER_NAME=openrouter
HWP_LLM_API_KEY=your_api_key_here
HWP_LLM_MODEL=your_model_here

# Optional:
# HWP_LLM_BASE_URL=https://your-provider.example/v1
# HWP_LLM_TEMPERATURE=0.7
# HWP_LLM_TIMEOUT_SEC=120
#
# Built-in HWP_PROVIDER_NAME presets include:
# openai, openrouter, deepseek, moonshot, kimi, siliconflow, groq, together, fireworks, perplexity, xai
#
# Backward-compatible aliases still supported:
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OPENAI_BASE_URL=
