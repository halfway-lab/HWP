#!/usr/bin/env bash
set -euo pipefail

INPUT="${1:-}"
if [ -z "$INPUT" ]; then
  echo "Usage: $0 \"your input text\""
  exit 1
fi

TMP_INPUT="$(mktemp)"
echo "$INPUT" > "$TMP_INPUT"

bash runs/run_sequential.sh "$TMP_INPUT"

rm -f "$TMP_INPUT"

# Print last round inner JSON of latest chain
LATEST=$(ls -t "$HOME/hwp-tests/logs"/chain_hwp_*.jsonl | head -n 1)
LAST_LINE=$(tail -n 1 "$LATEST")
echo "$LAST_LINE" | jq -r '.payloads[0].text'
