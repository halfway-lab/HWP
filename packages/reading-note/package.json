{
  "name": "@halfway-lab/reading-note",
  "version": "0.2.0",
  "description": "Reading-note extraction built on top of a local Half Way Protocol (HWP) runner.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halfway-lab/HWP.git",
    "directory": "packages/reading-note"
  },
  "homepage": "https://github.com/halfway-lab/HWP/tree/main/packages/reading-note",
  "bugs": {
    "url": "https://github.com/halfway-lab/HWP/issues"
  },
  "keywords": [
    "reading-note",
    "hwp",
    "halfway-protocol",
    "notes",
    "llm"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "test": "ts-node tests/reading-note.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "sideEffects": false,
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1",
    "@types/node": "^20.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
